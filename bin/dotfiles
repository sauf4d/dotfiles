#!/usr/bin/env bash

# =============================================================================
# Dotfiles Manager - Clean, Cross-Platform Installation Script
# =============================================================================
# Features: Interactive/Non-interactive, Profile-based, Cross-platform
# Supports: macOS (Darwin), Linux (Ubuntu, Fedora, Arch, etc.)
# Author: Veteran Programmer - Clean, Maintainable, Production-Ready Code
# =============================================================================

# Enable strict error handling
set -euo pipefail

# =============================================================================
# Configuration & Constants
# =============================================================================
readonly DEFAULT_ROOT="$HOME/.dotfiles"
readonly DEFAULT_PROFILE="core"
readonly DEFAULT_VERBOSE="false"
readonly SCRIPT_NAME="dotfiles"

# URLs - Easy to update
readonly REPO_URL="https://github.com/ved0el/dotfiles.git"
readonly INSTALL_COMMAND_URL="https://raw.githubusercontent.com/ved0el/dotfiles/main/bin/dotfiles"
readonly DOCS_URL="https://github.com/ved0el/dotfiles"

# Configuration file location
readonly CONFIG_FILE="$HOME/.zshenv"

# =============================================================================
# Cross-Platform Detection & Utilities
# =============================================================================
get_os_type() { uname -s; }

# Cross-platform sed in-place editing
sed_inplace() {
    local file="$1"; shift
    [[ "$(get_os_type)" == "Darwin" ]] && sed -i '' "$@" "$file" || sed -i "$@" "$file"
}

# Extract value from a saved config line. Handles three forms:
#   export VAR=value
#   export VAR="value"
#   export VAR="${VAR:-default}"   # env-override pattern from save_config
#
# For the third form, env-passed values win and the embedded default is used as
# fallback. Without this branch the literal pattern would be exported verbatim.
extract_config_value() {
    local var_name="$1"
    local config_file="$2"

    local line
    line=$(grep "^export ${var_name}=" "$config_file" 2>/dev/null | tail -1 || echo "")
    [[ -z "$line" ]] && return 1

    # Strip "export VAR=" prefix, then strip ALL surrounding quotes.
    # Using loops instead of single-strip to handle stacked extra quotes
    # (e.g. "value""" from a corrupted file) without leaving residue.
    local value="${line#*=}"
    while [[ "${value:0:1}" == '"' || "${value:0:1}" == "'" ]]; do value="${value:1}"; done
    while [[ "${value: -1:1}" == '"' || "${value: -1:1}" == "'" ]]; do value="${value%?}"; done

    # Resolve ${SAME_VAR:-default} fallback syntax safely (no eval).
    if [[ "$value" == '${'"$var_name"':-'*'}' ]]; then
        local env_val="${!var_name:-}"
        if [[ -n "$env_val" ]]; then
            value="$env_val"
        else
            value="${value#'${'"$var_name"':-'}"
            value="${value%'}'}"
        fi
    fi

    [[ -n "$value" ]] && echo "$value"
}

# =============================================================================
# Shared logging — colors, glyphs, _dotfiles_log_* helpers
# =============================================================================
# Source the POSIX log library. DOTFILES_ROOT may not be set yet (we're before
# init_script), so fall back to a hard-coded default that matches the install
# pattern.
_DF_LIB="${DOTFILES_ROOT:-$HOME/.dotfiles}/zsh/lib/log.sh"
if [[ -f "$_DF_LIB" ]]; then
    # shellcheck source=../zsh/lib/log.sh
    . "$_DF_LIB"
else
    # Last-resort fallback — _log.sh not present (fresh-machine bootstrap or
    # DOTFILES_ROOT points elsewhere). Define empty color vars and minimal log
    # stubs so `set -u` is happy and the script can still run.
    _DF_BOLD=''; _DF_RESET=''; _DF_RED=''; _DF_GREEN=''
    _DF_YELLOW=''; _DF_BLUE=''; _DF_MAGENTA=''; _DF_CYAN=''
    _DF_WHITE=''; _DF_GRAY=''
    _DF_CHECK='✓'; _DF_CROSS='✗'; _DF_ARROW='→'; _DF_BULLET='•'; _DF_WARN='⚠'
    _dotfiles_log_info()    { :; }
    _dotfiles_log_debug()   { :; }
    _dotfiles_log_dim()     { :; }
    _dotfiles_log_success() { :; }
    _dotfiles_log_step()    { echo "→ $*"; }
    _dotfiles_log_detail()  { echo "• $*"; }
    _dotfiles_log_result()  { echo "  $1: $2"; }
    _dotfiles_log_summary() { echo "✓ $*"; }
    _dotfiles_log_warning() { echo "⚠  $*" >&2; }
    _dotfiles_log_error()   { echo "✗ $*" >&2; }
fi
unset _DF_LIB

# Local aliases for shorter color/glyph references in this script
readonly RED="$_DF_RED" GREEN="$_DF_GREEN" YELLOW="$_DF_YELLOW"
readonly BLUE="$_DF_BLUE" MAGENTA="$_DF_MAGENTA" CYAN="$_DF_CYAN"
readonly WHITE="$_DF_WHITE" GRAY="$_DF_GRAY"
readonly BOLD="$_DF_BOLD" RESET="$_DF_RESET"
readonly CHECK="$_DF_CHECK" CROSS="$_DF_CROSS"
readonly ARROW="$_DF_ARROW" BULLET="$_DF_BULLET"

is_verbose() {
    [[ "${DOTFILES_VERBOSE:-$DEFAULT_VERBOSE}" == "true" ]]
}

# =============================================================================
# Validation Functions
# =============================================================================
# Validate profile value (returns 0 if valid, 1 if invalid)
validate_profile() {
    local profile="$1"
    local valid_profiles=("core" "full")

    for valid_profile in "${valid_profiles[@]}"; do
        [[ "$profile" == "$valid_profile" ]] && return 0
    done

    _dotfiles_log_error "Invalid profile '$profile'. Valid profiles: ${valid_profiles[*]}"
    return 1
}

is_interactive() { [[ -t 0 && -t 1 ]]; }

die() { _dotfiles_log_error "$1"; exit 1; }

# =============================================================================
# Banner & UI Functions
# =============================================================================
show_banner() {
    echo -e "${BOLD}${BLUE}╭────────────────────────────────────────────────────────────────╮${RESET}"
    echo -e "${BOLD}${BLUE}│${RESET}                    ${BOLD}${WHITE}🚀 Dotfiles Manager${RESET}                         ${BOLD}${BLUE}│${RESET}"
    echo -e "${BOLD}${BLUE}│${RESET}              ${GRAY}Clean, Cross-Platform Setup${RESET}                       ${BOLD}${BLUE}│${RESET}"
    echo -e "${BOLD}${BLUE}╰────────────────────────────────────────────────────────────────╯${RESET}"
    echo
}

# Show section header (always-print — CLI progress marker)
show_section() {
    echo; echo -e "${BOLD}${MAGENTA}◆ $1${RESET}"
    echo -e "${GRAY}────────────────────────────────────────────────────────────────${RESET}"
}

# Show subsection header (only in verbose mode)
show_subsection() {
    is_verbose || return 0
    echo -e "${CYAN}${BULLET}${RESET} ${BOLD}${CYAN}$1${RESET}";
}

# =============================================================================
# Configuration Management
# =============================================================================
# Set default values for all dotfiles variables.
# Also runs a one-time migration: legacy profile names (minimal/server) are
# upgraded to their replacements (core/full) and persisted to ~/.zshenv.
# Order matters: init_script calls load_config BEFORE set_defaults, so the
# legacy value (if any) is already exported by the time this runs.
set_defaults() {
    export DOTFILES_ROOT="${DOTFILES_ROOT:-$DEFAULT_ROOT}"
    export DOTFILES_PROFILE="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    export DOTFILES_VERBOSE="${DOTFILES_VERBOSE:-$DEFAULT_VERBOSE}"

    # One-time profile-name migration (legacy → new). save_config persists.
    local _migrated_profile=""
    case "${DOTFILES_PROFILE:-}" in
        minimal) _migrated_profile="core" ;;
        server)  _migrated_profile="full" ;;
    esac
    if [[ -n "$_migrated_profile" ]]; then
        _dotfiles_log_warning "DOTFILES_PROFILE '${DOTFILES_PROFILE}' migrated to '${_migrated_profile}' — saved to ${CONFIG_FILE}"
        export DOTFILES_PROFILE="$_migrated_profile"
        save_config
    fi
}

load_config() {
    [[ ! -f "$CONFIG_FILE" ]] && {
        _dotfiles_log_debug "No configuration file found at $CONFIG_FILE"
        return 0
    }

    _dotfiles_log_debug "Loading configuration from $CONFIG_FILE"

    # Load configuration values with fallbacks
    local value

    if value=$(extract_config_value "DOTFILES_ROOT" "$CONFIG_FILE" 2>/dev/null || true); then
        [[ -n "$value" ]] && export DOTFILES_ROOT="$value"
        _dotfiles_log_debug "Loaded DOTFILES_ROOT: ${value:-default}"
    fi

    if value=$(extract_config_value "DOTFILES_PROFILE" "$CONFIG_FILE" 2>/dev/null || true); then
        [[ -n "$value" ]] && export DOTFILES_PROFILE="$value"
        _dotfiles_log_debug "Loaded DOTFILES_PROFILE: ${value:-default}"
    fi

    if value=$(extract_config_value "DOTFILES_VERBOSE" "$CONFIG_FILE" 2>/dev/null || true); then
        [[ -n "$value" ]] && export DOTFILES_VERBOSE="$value"
        _dotfiles_log_debug "Loaded DOTFILES_VERBOSE: ${value:-default}"
    fi

    _dotfiles_log_debug "Configuration loaded successfully"
}

save_config() {
    # Ensure config directory exists
    local config_dir
    config_dir=$(dirname "$CONFIG_FILE")
    [[ ! -d "$config_dir" ]] && mkdir -p "$config_dir"

    # Rotate backups: keep last 3 (.backup → .backup.1 → .backup.2)
    if [[ -f "$CONFIG_FILE" ]]; then
        [[ -f "${CONFIG_FILE}.backup.2" ]] && mv "${CONFIG_FILE}.backup.2" "${CONFIG_FILE}.backup.3" 2>/dev/null || true
        [[ -f "${CONFIG_FILE}.backup.1" ]] && mv "${CONFIG_FILE}.backup.1" "${CONFIG_FILE}.backup.2" 2>/dev/null || true
        [[ -f "${CONFIG_FILE}.backup"   ]] && mv "${CONFIG_FILE}.backup"   "${CONFIG_FILE}.backup.1" 2>/dev/null || true
        cp "$CONFIG_FILE" "${CONFIG_FILE}.backup" 2>/dev/null || true
    fi

    # Remove existing dotfiles block (exports + header comment)
    if [[ -f "$CONFIG_FILE" ]]; then
        sed_inplace "$CONFIG_FILE" '/^export DOTFILES_/d'
        sed_inplace "$CONFIG_FILE" '/^# Dotfiles Configuration/d'
    fi

    # Append new configuration block.
    # Escape \${VAR:-default} so the LITERAL fallback syntax lands in zshenv —
    # this lets env-passed values (e.g. DOTFILES_VERBOSE=true) override the
    # saved defaults at shell-startup time. Without the escape, the file would
    # contain unconditional exports that clobber the user's env.
    local _root="${DOTFILES_ROOT:-$DEFAULT_ROOT}"
    local _profile="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    local _verbose="${DOTFILES_VERBOSE:-$DEFAULT_VERBOSE}"
    cat >> "$CONFIG_FILE" << EOF

# Dotfiles Configuration
export DOTFILES_ROOT="\${DOTFILES_ROOT:-$_root}"
export DOTFILES_PROFILE="\${DOTFILES_PROFILE:-$_profile}"
export DOTFILES_VERBOSE="\${DOTFILES_VERBOSE:-$_verbose}"
EOF

    _dotfiles_log_debug "Configuration saved to $CONFIG_FILE"
}

# =============================================================================
# Environment Setup
# =============================================================================
setup_environment() {
    # Always show progress, detailed section only in verbose mode
    _dotfiles_log_step "Setting up environment..."
    show_section "Configuration Setup"

    # Load existing configuration and set defaults
    load_config
    set_defaults

    # Auto-detect repository
    if [[ -z "${DOTFILES_REPO:-}" ]]; then
        if [[ -d "$SCRIPT_DIR/.git" ]]; then
            DOTFILES_REPO=$(cd "$SCRIPT_DIR" && git remote get-url origin 2>/dev/null || echo "")
            _dotfiles_log_debug "Auto-detected repository from local git"
        else
            DOTFILES_REPO="$REPO_URL"
            _dotfiles_log_debug "Using default repository"
        fi
    fi
    export DOTFILES_REPO

    # Validate settings (show error but don't exit)
    validate_profile "$DOTFILES_PROFILE" || {
        _dotfiles_log_warning "Using default profile '$DEFAULT_PROFILE'"
        export DOTFILES_PROFILE="$DEFAULT_PROFILE"
    }
}

# =============================================================================
# Repository Management
# =============================================================================
is_fresh_install() {
    [[ ! -d "$DOTFILES_ROOT/.git" ]]
}

clone_repository_if_missing() {
    # Only used during install. Update is a separate command (no git in install).
    if ! is_fresh_install; then
        _dotfiles_log_debug "Repository already at $DOTFILES_ROOT (skip clone)"
        return 0
    fi

    show_section "Repository Setup"
    _dotfiles_log_step "Cloning dotfiles repository"

    if [[ -z "$DOTFILES_REPO" ]]; then
        _dotfiles_log_error "Repository URL not specified (set DOTFILES_REPO)"
        return 1
    fi
    _dotfiles_log_detail "Source: $DOTFILES_REPO"

    git clone "$DOTFILES_REPO" "$DOTFILES_ROOT" >/dev/null 2>&1 || {
        _dotfiles_log_error "Failed to clone $DOTFILES_REPO"
        return 1
    }
    cd "$DOTFILES_ROOT"
    local head_sha
    head_sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
    _dotfiles_log_detail "Repository cloned at $DOTFILES_ROOT (HEAD: $head_sha)"
}

# -----------------------------------------------------------------------------
# Update flow — git-only, safe stash/rebase/pop. Separate from install so that
# install never fails on a dirty working tree, and updates have a clear recovery
# path on conflict.
# -----------------------------------------------------------------------------
update_dotfiles() {
    local do_stash=false
    [[ "${1:-}" == "--stash" ]] && do_stash=true

    if [[ ! -d "$DOTFILES_ROOT/.git" ]]; then
        _dotfiles_log_error "Not a git repository: $DOTFILES_ROOT"
        _dotfiles_log_dim "Run 'dotfiles install' first to clone the repo."
        return 1
    fi
    cd "$DOTFILES_ROOT" || return 1

    # Pre-flight: abort if mid-rebase or mid-merge — user must resolve manually
    if [[ -d .git/rebase-merge || -d .git/rebase-apply ]]; then
        _dotfiles_log_error "Repository is mid-rebase. Resolve before updating."
        _dotfiles_log_dim "Use 'git rebase --continue' or 'git rebase --abort'"
        return 1
    fi
    if [[ -f .git/MERGE_HEAD ]]; then
        _dotfiles_log_error "Repository is mid-merge. Resolve before updating."
        _dotfiles_log_dim "Use 'git merge --abort' or commit the merge."
        return 1
    fi

    # Pre-flight: must be on a branch (not detached HEAD)
    local branch
    branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || {
        _dotfiles_log_error "Detached HEAD — checkout a branch before updating."
        return 1
    }
    local remote_branch="${DOTFILES_BRANCH:-$branch}"

    _dotfiles_log_step "Updating dotfiles (branch: $branch)"

    # Detect dirty state: tracked changes OR untracked files
    local was_dirty=false stash_ref=""
    if ! git diff --quiet HEAD 2>/dev/null || \
       [[ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ]]; then
        if ! $do_stash; then
            _dotfiles_log_error "Local changes detected. Resolve before updating, or pass --stash."
            _dotfiles_log_dim "Options:"
            _dotfiles_log_dim "  git stash && dotfiles update && git stash pop   # manual"
            _dotfiles_log_dim "  dotfiles update --stash                          # auto-stash + restore"
            _dotfiles_log_dim "  git commit -am 'WIP' && dotfiles update          # commit first"
            return 1
        fi
        was_dirty=true
        # `git stash create` returns commit SHA without touching refs
        stash_ref="$(git stash create -u 2>/dev/null)"
        if [[ -z "$stash_ref" ]]; then
            _dotfiles_log_error "Failed to create stash for local changes"
            return 1
        fi
        git stash store -m "dotfiles auto-stash $(date '+%Y-%m-%d %H:%M:%S')" "$stash_ref" >/dev/null 2>&1
        git reset --hard HEAD >/dev/null 2>&1
        git clean -fd >/dev/null 2>&1
        _dotfiles_log_detail "Local changes stashed (stash@{0})"
    fi

    # Pull with rebase — do NOT silence the error, let user see git's diagnostic
    if ! git pull --rebase origin "$remote_branch"; then
        git rebase --abort 2>/dev/null
        _dotfiles_log_error "Pull failed (see git output above)"
        if $was_dirty; then
            _dotfiles_log_warning "Your local changes are preserved in stash@{0}"
            _dotfiles_log_warning "Recovery: git stash list  →  git stash pop"
        fi
        return 1
    fi

    # Restore local changes if we stashed them
    if $was_dirty; then
        if ! git stash pop 2>/dev/null; then
            _dotfiles_log_warning "Conflicts while restoring local changes"
            _dotfiles_log_warning "Stashed changes remain in stash@{0}. Resolve with:"
            _dotfiles_log_dim "  git stash show -p stash@{0}    # preview"
            _dotfiles_log_dim "  git stash pop                  # retry (will conflict again)"
            _dotfiles_log_dim "  git checkout --theirs <file>   # take stash version"
            return 1
        fi
    fi

    _dotfiles_log_summary "Updated to $(git rev-parse --short HEAD). Run: dotfiles install (or 'dotfiles sync')"
}

# -----------------------------------------------------------------------------
# Sync — update + reinstall in one go
# -----------------------------------------------------------------------------
sync_dotfiles() {
    update_dotfiles "${1:-}" && install_dotfiles
}

# =============================================================================
# Symlink Management
# =============================================================================
readonly EXCLUDE_PATTERNS=(
    "README.md" "CLAUDE.md" ".gitignore" "install" "bin" "config"
    "zsh" "docs" "zshenv" ".vscode" ".git" "*.zwc" "*.zwc.old"
)

should_exclude() {
    local item="$1"
    for pattern in "${EXCLUDE_PATTERNS[@]}"; do
        # Use glob matching for patterns with wildcards, exact match otherwise
        if [[ "$pattern" == *"*"* ]]; then
            [[ "$item" == $pattern ]] && return 0
        else
            [[ "$item" == "$pattern" ]] && return 0
        fi
    done
    return 1
}

# Create a symlink with proper error handling
create_single_symlink() {
    local source_path="$1"
    local target_path="$2"
    local display_name="$3"

    # Remove existing symlink — refuse to rm -rf a real directory
    if [[ -L "$target_path" ]]; then
        rm -f "$target_path" || { _dotfiles_log_error "Failed to remove symlink: $target_path"; return 1; }
    elif [[ -e "$target_path" ]]; then
        _dotfiles_log_warning "Skipping $target_path — already exists and is not a symlink (remove manually if intended)"
        return 1
    fi

    # Create symlink (always do the work, only show output if verbose)
    if ln -sf "$source_path" "$target_path"; then
        is_verbose && _dotfiles_log_dim "${GREEN}${CHECK}${RESET} $display_name ${MAGENTA}${ARROW}${RESET} $target_path"
        return 0
    else
        _dotfiles_log_error "Failed to create symlink: $source_path -> $target_path"
        return 1
    fi
}

# Link files from source directory to target directory
link_directory_files() {
    local source_dir="$1"
    local target_prefix="$2"
    local subsection_title="$3"

    [[ ! -d "$source_dir" ]] && return 0

    show_subsection "$subsection_title"

    local linked_count=0
    local failed_count=0

    for item in "$source_dir"/*; do
        [[ ! -e "$item" ]] && continue  # Skip if item doesn't exist

        local name=$(basename "$item")
        local target="$target_prefix$name"

        # Caller-provided exclusions via DOTFILES_CONFIG_EXCLUDE (colon-delimited).
        # Same format as check_directory_symlinks and remove_symlinks_from_dir use.
        if [[ -n "${DOTFILES_CONFIG_EXCLUDE:-}" ]] && \
           [[ ":${DOTFILES_CONFIG_EXCLUDE}:" == *":${name}:"* ]]; then
            continue
        fi

        # Ensure target directory exists
        local target_dir
        target_dir=$(dirname "$target")
        [[ ! -d "$target_dir" ]] && mkdir -p "$target_dir"

        if ! should_exclude "$name" && [[ -f "$item" || -d "$item" ]]; then
            if create_single_symlink "$item" "$target" "$name"; then
                ((linked_count++))
            else
                ((failed_count++))
            fi
        fi
    done

    _dotfiles_log_debug "Linked $linked_count files from $source_dir"
    [[ $failed_count -gt 0 ]] && _dotfiles_log_warning "Failed to link $failed_count files"
}

create_symlinks() {
    # Always show progress message, detailed section only in verbose mode
    _dotfiles_log_step "Creating symlinks..."
    show_section "Creating symlinks..."

    # Link dotfiles (files in root directory)
    link_directory_files "$DOTFILES_ROOT" "$HOME/." "Linking dotfiles..."

    # Link config files (skip 'claude' — it lives at ~/.claude, not ~/.config/claude)
    mkdir -p "$HOME/.config"
    DOTFILES_CONFIG_EXCLUDE="claude" \
        link_directory_files "$DOTFILES_ROOT/config" "$HOME/.config/" "Linking config files..."

    # Link Claude Code config files individually into ~/.claude/
    if [[ -d "$DOTFILES_ROOT/config/claude" ]]; then
        mkdir -p "$HOME/.claude"
        link_directory_files "$DOTFILES_ROOT/config/claude" "$HOME/.claude/" "Linking Claude Code config..."
    fi
}

# Check symlinks in a directory
check_directory_symlinks() {
    local source_dir="$1"
    local target_prefix="$2"
    local subsection_title="$3"
    local total_links_ref="$4"
    local broken_links_ref="$5"

    [[ ! -d "$source_dir" ]] && return 0

    show_subsection "$subsection_title"

    local item_count=0

    for item in "$source_dir"/*; do
        [[ ! -e "$item" ]] && continue

        local name=$(basename "$item")
        local target="$target_prefix$name"

        # Honor caller-provided ":"-separated exclusion list
        if [[ -n "${DOTFILES_CONFIG_EXCLUDE:-}" ]] && [[ ":${DOTFILES_CONFIG_EXCLUDE}:" == *":${name}:"* ]]; then
            continue
        fi

        if ! should_exclude "$name" && [[ -f "$item" || -d "$item" ]]; then
            ((item_count++))
            if [[ -L "$target" ]] && [[ -e "$target" ]]; then
                is_verbose && _dotfiles_log_dim "${GREEN}${CHECK}${RESET} $name ${MAGENTA}${ARROW}${RESET} $target"
                printf -v "$total_links_ref" '%d' "$((${!total_links_ref} + 1))"
            else
                _dotfiles_log_error "Broken or missing: $target"
                printf -v "$broken_links_ref" '%d' "$((${!broken_links_ref} + 1))"
            fi
        fi
    done

    _dotfiles_log_debug "Checked $item_count items in $source_dir"
}

verify_symlinks() {
    # Always show progress, detailed section only in verbose mode
    _dotfiles_log_step "Verifying symlinks..."
    show_section "Verifying symlinks..."

    [[ -n "$DOTFILES_ROOT" ]] || { _dotfiles_log_error "DOTFILES_ROOT is not set"; return 1; }
    [[ -d "$DOTFILES_ROOT" ]] || { _dotfiles_log_error "Dotfiles directory not found: $DOTFILES_ROOT"; return 1; }

    local total_links=0
    local broken_links=0

    # Check dotfiles symlinks
    check_directory_symlinks "$DOTFILES_ROOT" "$HOME/." "Checking dotfiles symlinks..." total_links broken_links

    # Check config files symlinks (skip 'claude' — checked separately below)
    DOTFILES_CONFIG_EXCLUDE="claude" \
        check_directory_symlinks "$DOTFILES_ROOT/config" "$HOME/.config/" "Checking config files symlinks..." total_links broken_links

    # Check Claude Code config symlinks (~/.claude/)
    [[ -d "$DOTFILES_ROOT/config/claude" ]] && \
        check_directory_symlinks "$DOTFILES_ROOT/config/claude" "$HOME/.claude/" "Checking Claude Code config symlinks..." total_links broken_links

    # Summary (always show)
    echo
    if [[ $broken_links -eq 0 ]]; then
        _dotfiles_log_success "All $total_links symlinks are working"
        return 0
    else
        _dotfiles_log_warning "Found $broken_links broken symlinks out of $total_links total"
        return 1
    fi
}

# Check which packages in the active profile are not installed
verify_packages() {
    _dotfiles_log_step "Checking package status for profile: $DOTFILES_PROFILE"
    show_section "Package Status"

    command -v zsh &>/dev/null || {
        _dotfiles_log_warning "zsh not found, cannot check packages"
        return 0
    }

    # Run packages with VERBOSE=false; init_package_template prints a warning
    # line to stderr for each not-installed package: "[dotfiles] X not installed"
    local warnings
    warnings=$(
        DOTFILES_VERBOSE=false \
        DOTFILES_PROFILE="$DOTFILES_PROFILE" \
        DOTFILES_ROOT="$DOTFILES_ROOT" \
        zsh -c '
            setopt NULL_GLOB
            [[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$PATH:$HOME/.local/bin"
            source "$DOTFILES_ROOT/zsh/lib/platform.zsh"
            source "$DOTFILES_ROOT/zsh/lib/installer.zsh"

            typeset -a pkg_dirs
            case "$DOTFILES_PROFILE" in
                core|minimal) pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core") ;;
                *)            pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core"
                                        "$DOTFILES_ROOT/zsh/packages/full") ;;
            esac

            for pkg_dir in "$pkg_dirs[@]"; do
                [[ -d "$pkg_dir" ]] || continue
                for pkg_file in "$pkg_dir"/*.zsh(N); do
                    source "$pkg_file"
                done
            done
        ' 2>&1 | grep '^\[dotfiles\]'
    )

    echo
    if [[ -z "$warnings" ]]; then
        _dotfiles_log_success "All packages for profile '$DOTFILES_PROFILE' are installed"
        return 0
    else
        _dotfiles_log_warning "Not installed packages:"
        while IFS= read -r line; do
            echo -e "  ${YELLOW}${BULLET}${RESET} $line"
        done <<< "$warnings"
        echo
        _dotfiles_log_info "Run 'dotfiles install' to install missing packages"
        return 1
    fi
}

# Combined verify: symlinks + packages
verify_all() {
    local sym_rc=0 pkg_rc=0
    verify_symlinks || sym_rc=$?
    echo
    verify_packages || pkg_rc=$?
    [[ $sym_rc -eq 0 && $pkg_rc -eq 0 ]]
}

# =============================================================================
# Package Installation
# =============================================================================
install_packages() {
    # Always show progress, detailed section only in verbose mode
    _dotfiles_log_step "Installing packages for profile: $DOTFILES_PROFILE"
    show_section "Package Installation"

    command -v zsh &>/dev/null || {
        _dotfiles_log_warning "zsh not found, skipping package installation"
        return 0
    }

    echo
    _dotfiles_log_info "Checking packages for profile: $DOTFILES_PROFILE"
    echo

    # Package files use zsh-specific syntax (typeset, setopt, glob qualifiers).
    # Must run in a zsh subprocess — bash cannot source them correctly.
    # DOTFILES_VERBOSE is forced true here so package lifecycle output is visible
    # during install. The user's saved DOTFILES_VERBOSE only affects normal shell startup.
    local exit_code=0
    DOTFILES_INSTALL=true \
    DOTFILES_VERBOSE=true \
    DOTFILES_PROFILE="$DOTFILES_PROFILE" \
    DOTFILES_ROOT="$DOTFILES_ROOT" \
    zsh -c '
        setopt NULL_GLOB
        [[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$PATH:$HOME/.local/bin"
        source "$DOTFILES_ROOT/zsh/lib/platform.zsh"
        source "$DOTFILES_ROOT/zsh/lib/installer.zsh"

        typeset -a pkg_dirs
        case "$DOTFILES_PROFILE" in
            core|minimal) pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core") ;;
            *)            pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core"
                                    "$DOTFILES_ROOT/zsh/packages/full") ;;
        esac

        for pkg_dir in "$pkg_dirs[@]"; do
            [[ -d "$pkg_dir" ]] || continue
            for pkg_file in "$pkg_dir"/*.zsh(N); do
                source "$pkg_file"
            done
        done
    ' || exit_code=$?

    [[ $exit_code -ne 0 ]] && _dotfiles_log_error "Package installation encountered errors (exit $exit_code)"

    echo
    _dotfiles_log_success "Package check and installation completed"

    # Show profile-specific package list
    echo
    _dotfiles_log_info "Profile '$DOTFILES_PROFILE' includes:"
    case "$DOTFILES_PROFILE" in
        core|minimal)
            echo -e "  ${CYAN}${BULLET}${RESET} tmux, sheldon"
            ;;
        full|server)
            echo -e "  ${CYAN}${BULLET}${RESET} tmux, sheldon (core)"
            echo -e "  ${CYAN}${BULLET}${RESET} bat, fzf, eza, fd, jq, ripgrep, zoxide, vfox"
            ;;
    esac

    echo
    echo -e "  ${YELLOW}→${RESET} Reload your shell to activate: ${BOLD}exec zsh${RESET}"
}

# =============================================================================
# Profile Management
# =============================================================================
configure_profile() {
    _dotfiles_log_info "Configuring profile: $DOTFILES_PROFILE"
    save_config
    _dotfiles_log_success "Profile configured successfully"
}

# =============================================================================
# Main Installation Flow
# =============================================================================
install_dotfiles() {
    show_banner

    local is_install=false
    is_fresh_install && is_install=true

    if $is_install; then
        _dotfiles_log_step "Starting dotfiles installation (fresh install)"
    else
        _dotfiles_log_step "Starting dotfiles update"
    fi

    # Step 1: Setup environment (load config, set defaults)
    setup_environment

    # Step 2: Clone the repository if missing (no git pull — use 'dotfiles update')
    clone_repository_if_missing || {
        _dotfiles_log_error "Failed to setup repository"
        return 1
    }

    # Step 3: (Re)link the files (always relink to ensure latest structure)
    create_symlinks

    # Step 4: Install / verify packages for active profile
    install_packages

    # Step 5: Save configuration
    configure_profile

    # Success message
    echo
    if $is_install; then
        echo -e "${BOLD}${GREEN}╭────────────────────────────────────────────────────────────────╮${RESET}"
        echo -e "${BOLD}${GREEN}│${RESET}${BOLD}${WHITE}                    🎉 Installation Complete!                   ${RESET}${BOLD}${GREEN}│${RESET}"
        echo -e "${BOLD}${GREEN}╰────────────────────────────────────────────────────────────────╯${RESET}"
        echo

        _dotfiles_log_success "Profile '$DOTFILES_PROFILE' is now active"

        # Show what's included
        echo
        echo -e "${BOLD}${WHITE}What's Included:${RESET}"
        case "$DOTFILES_PROFILE" in
            core|minimal)
                echo -e "  ${GREEN}${CHECK}${RESET} Shell essentials (zsh, sheldon, tmux)"
                ;;
            full|server)
                echo -e "  ${GREEN}${CHECK}${RESET} Shell + utilities + vfox version manager"
                ;;
        esac
    else
        echo -e "${BOLD}${GREEN}╭────────────────────────────────────────────────────────────────╮${RESET}"
        echo -e "${BOLD}${GREEN}│${RESET}${BOLD}${WHITE}                      ✨ Update Complete!                       ${RESET}${BOLD}${GREEN}│${RESET}"
        echo -e "${BOLD}${GREEN}╰────────────────────────────────────────────────────────────────╯${RESET}"
        echo

        _dotfiles_log_success "Dotfiles updated to latest version"
        _dotfiles_log_success "Profile '$DOTFILES_PROFILE' is active"
    fi

    # Step 6: Source a new zsh shell (always)
    echo
    if command -v zsh &>/dev/null; then
        _dotfiles_log_info "Starting new zsh shell..."
        exec zsh -l
    else
        _dotfiles_log_warning "zsh not found, please restart your terminal manually"
    fi
}

# =============================================================================
# Uninstallation
# =============================================================================
# Remove symlinks from a directory
remove_symlinks_from_dir() {
    local source_dir="$1"
    local target_prefix="$2"
    local unlink_count_ref="$3"

    [[ ! -d "$source_dir" ]] && return 0

    for item in "$source_dir"/*; do
        [[ ! -e "$item" ]] && continue

        local name=$(basename "$item")
        local target="$target_prefix$name"

        # Honor caller-provided ":"-separated exclusion list
        if [[ -n "${DOTFILES_CONFIG_EXCLUDE:-}" ]] && [[ ":${DOTFILES_CONFIG_EXCLUDE}:" == *":${name}:"* ]]; then
            continue
        fi

        local link_target
        link_target="$(readlink "$target" 2>/dev/null)"
        if [[ -L "$target" ]] && [[ "$link_target" == "$DOTFILES_ROOT/"* || "$link_target" == "$DOTFILES_ROOT" ]]; then
            rm "$target" && printf -v "$unlink_count_ref" '%d' "$((${!unlink_count_ref} + 1))"
        fi
    done
}

uninstall_dotfiles() {
    _dotfiles_log_warning "This will remove all dotfiles symlinks, packages, and the repo dir"

    if is_interactive; then
        echo -n "Are you sure? [y/N]: "
        read -r response
        [[ ! "$response" =~ ^[Yy]$ ]] && { _dotfiles_log_info "Uninstallation cancelled"; return 0; }
    fi

    show_section "Uninstall"

    # 1. Reverse-iterate active-profile packages and dispatch pkg_uninstall
    _dotfiles_log_step "Asking packages to uninstall (reverse order)"
    local -a all_pkgs=() failed_pkgs=()
    while IFS= read -r f; do all_pkgs+=("$f"); done < <(_iter_profile_packages)

    local i pkg_file pkg_name rc
    for (( i=${#all_pkgs[@]}-1; i>=0; i-- )); do
        pkg_file="${all_pkgs[$i]}"
        pkg_name="$(basename "$pkg_file" .zsh)"
        pkg_name="${pkg_name#[0-9][0-9]-}"
        _dispatch_pkg_hook "$pkg_file" pkg_uninstall
        rc=$?
        case $rc in
            0) _dotfiles_log_result "$pkg_name" "uninstalled" ;;
            2) _dotfiles_log_error "$pkg_name: pkg_uninstall is REQUIRED but missing"
               failed_pkgs+=("$pkg_name|pkg_uninstall hook not defined|N/A|implement pkg_uninstall in $pkg_file") ;;
            *)
               local _err="${_PKG_UNINSTALL_ERROR:-rc=$rc}"
               local _rem="${_PKG_UNINSTALL_REMAINING:-see hook output above}"
               local _rec="${_PKG_UNINSTALL_RECOVERY:-investigate manually}"
               failed_pkgs+=("$pkg_name|$_err|$_rem|$_rec")
               unset _PKG_UNINSTALL_ERROR _PKG_UNINSTALL_REMAINING _PKG_UNINSTALL_RECOVERY
               ;;
        esac
    done

    # 2. Print failure summary (cause + remaining + recovery, per PRD contract)
    if [[ ${#failed_pkgs[@]} -gt 0 ]]; then
        echo
        _dotfiles_log_warning "${#failed_pkgs[@]} package uninstall(s) failed:"
        local entry name err rem rec
        for entry in "${failed_pkgs[@]}"; do
            IFS='|' read -r name err rem rec <<< "$entry"
            _dotfiles_log_warning "$name:"
            _dotfiles_log_dim "  error:     $err"
            _dotfiles_log_dim "  remaining: $rem"
            _dotfiles_log_dim "  recovery:  $rec"
        done
        echo
        _dotfiles_log_warning "Continuing with symlink and repo removal."
    fi

    # 3. Remove symlinks (preserves CONFIG_EXCLUDE handling)
    local unlink_count=0
    remove_symlinks_from_dir "$DOTFILES_ROOT" "$HOME/." unlink_count
    DOTFILES_CONFIG_EXCLUDE="claude" \
        remove_symlinks_from_dir "$DOTFILES_ROOT/config" "$HOME/.config/" unlink_count
    [[ -d "$DOTFILES_ROOT/config/claude" ]] && \
        remove_symlinks_from_dir "$DOTFILES_ROOT/config/claude" "$HOME/.claude/" unlink_count

    # 4. Remove DOTFILES_* exports from zshenv
    [[ -f "$CONFIG_FILE" ]] && {
        sed_inplace "$CONFIG_FILE" '/^export DOTFILES_/d'
        sed_inplace "$CONFIG_FILE" '/^# Dotfiles Configuration/d'
    }

    # 5. Remove the dotfiles directory — validate path before deletion
    # Guards against a misconfigured DOTFILES_ROOT wiping unintended directories
    if [[ -d "$DOTFILES_ROOT" ]]; then
        if [[ "$DOTFILES_ROOT" != "$HOME/"* ]] || [[ ! -d "$DOTFILES_ROOT/.git" ]]; then
            _dotfiles_log_error "Refusing to remove '$DOTFILES_ROOT' — not a git repo under \$HOME"
            _dotfiles_log_error "Delete it manually if intended: rm -rf '$DOTFILES_ROOT'"
            return 1
        fi
        rm -rf "$DOTFILES_ROOT"
    fi

    # Clean up config backups created by save_config
    rm -f "${CONFIG_FILE}.backup" "${CONFIG_FILE}.backup.1" \
          "${CONFIG_FILE}.backup.2" "${CONFIG_FILE}.backup.3" 2>/dev/null || true

    echo
    if [[ ${#failed_pkgs[@]} -eq 0 ]]; then
        _dotfiles_log_summary "Uninstalled $unlink_count symlinks, all packages, and dotfiles repo"
    else
        _dotfiles_log_summary "Uninstalled $unlink_count symlinks and dotfiles repo. ${#failed_pkgs[@]} package(s) need manual cleanup (see above)."
    fi
}

# =============================================================================
# Clean — safe symlink + leftover cleanup
# =============================================================================
# Algorithm guarantees:
#   1. Only touches symlinks — never files or directories
#   2. Only removes links whose target points INTO the dotfiles repo
#      (user's own symlinks to other locations are never touched)
#   3. Only removes links whose target is missing (active links stay)
#   4. mise leftovers (~/.local/share/mise etc.) → hint only, never auto-delete
#   5. Dry-run by default; --force required to apply
clean_dotfiles() {
    local force=false
    [[ "${1:-}" == "--force" ]] && force=true

    cd "$DOTFILES_ROOT" 2>/dev/null || {
        _dotfiles_log_error "DOTFILES_ROOT not accessible: $DOTFILES_ROOT"
        return 1
    }

    show_section "Clean"
    if $force; then
        _dotfiles_log_step "Removing orphaned symlinks and stale state"
    else
        _dotfiles_log_step "Scanning for orphaned state (dry-run)"
        _dotfiles_log_detail "Pass --force to actually apply removals."
    fi

    # (dir, max-depth) — restrict $HOME to direct children so links also seen
    # under $HOME/.config etc. don't double-count.
    local scan_specs=("$HOME/.config:2" "$HOME/.claude:2" "$HOME:1")
    local found=0 removed=0
    local link target resolved dir maxdepth

    for spec in "${scan_specs[@]}"; do
        dir="${spec%:*}"
        maxdepth="${spec#*:}"
        [[ -d "$dir" ]] || continue
        while IFS= read -r link; do
            target="$(readlink "$link" 2>/dev/null)" || continue
            resolved="$(cd "$(dirname "$link")" 2>/dev/null && readlink -f "$link" 2>/dev/null || true)"

            # Skip anything that doesn't point into our repo
            if [[ "$target" != "$DOTFILES_ROOT"* && "$resolved" != "$DOTFILES_ROOT"* ]]; then
                continue
            fi

            # Active link — target exists. Leave it alone.
            [[ -e "$resolved" ]] && continue

            ((found++))
            if $force; then
                if rm "$link" 2>/dev/null; then
                    ((removed++))
                    _dotfiles_log_success "Removed: $link → $target"
                else
                    _dotfiles_log_warning "Failed to remove: $link"
                fi
            else
                _dotfiles_log_detail "Would remove: $link → $target"
            fi
        done < <(find "$dir" -mindepth 1 -maxdepth "$maxdepth" -type l 2>/dev/null)
    done

    # Per-package clean dispatch
    _dotfiles_log_step "Asking packages to declare cleanable state"
    local pkg_file pkg_name rc
    local clean_arg=""
    $force && clean_arg="--force"
    while IFS= read -r pkg_file; do
        pkg_name="$(basename "$pkg_file" .zsh)"
        pkg_name="${pkg_name#[0-9][0-9]-}"
        # Pass force flag via env var; hook reads ${DOTFILES_CLEAN_FORCE:-} to decide dry-run vs apply
        DOTFILES_CLEAN_FORCE="$clean_arg" _dispatch_pkg_hook "$pkg_file" pkg_clean
        rc=$?
        case $rc in
            0) ;;  # success — hook already printed its own status
            2) is_verbose && _dotfiles_log_dim "$pkg_name: no pkg_clean defined (skip)" ;;
            *) _dotfiles_log_warning "$pkg_name: clean returned $rc" ;;
        esac
    done < <(_iter_profile_packages)

    if [[ $found -eq 0 ]]; then
        _dotfiles_log_summary "Nothing to clean (symlinks)"
    elif $force; then
        _dotfiles_log_summary "Removed $removed of $found orphaned symlink(s)"
    else
        _dotfiles_log_summary "Found $found orphaned symlink(s). Re-run with --force to apply."
    fi
}

# =============================================================================
# Doctor — read-only diagnostics
# =============================================================================
# Reports health of: required tools, symlinks, package install status,
# PATH sanity, vfox SDK availability. Never modifies state.
# Exit code = number of issues found (0 = healthy).
doctor_dotfiles() {
    local issues=0

    show_section "Doctor"

    # 1. Required tools
    _dotfiles_log_step "Checking required tools"
    local tool
    for tool in git curl zsh; do
        if command -v "$tool" >/dev/null 2>&1; then
            _dotfiles_log_result "$tool" "$(command -v "$tool")"
        else
            _dotfiles_log_error "$tool not found in PATH"
            ((issues++))
        fi
    done

    # 2. Repository state
    _dotfiles_log_step "Checking repository"
    if [[ -d "$DOTFILES_ROOT/.git" ]]; then
        local head_sha branch dirty="clean"
        head_sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo "?")"
        branch="$(git -C "$DOTFILES_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo "detached")"
        if ! git -C "$DOTFILES_ROOT" diff --quiet HEAD 2>/dev/null; then
            dirty="dirty"
        fi
        _dotfiles_log_result "repo" "$DOTFILES_ROOT @ $branch $head_sha ($dirty)"
    else
        _dotfiles_log_error "Not a git repository: $DOTFILES_ROOT"
        ((issues++))
    fi

    # 3. Symlink integrity — count broken/orphaned (don't print each)
    _dotfiles_log_step "Checking symlinks"
    local broken=0
    # Same (dir:maxdepth) specs as clean_dotfiles for consistent scan coverage
    local scan_specs=("$HOME/.config:2" "$HOME/.claude:2" "$HOME:1")
    local link resolved dir maxdepth spec
    for spec in "${scan_specs[@]}"; do
        dir="${spec%:*}"
        maxdepth="${spec#*:}"
        [[ -d "$dir" ]] || continue
        while IFS= read -r link; do
            resolved="$(cd "$(dirname "$link")" 2>/dev/null && readlink -f "$link" 2>/dev/null || true)"
            if [[ "$resolved" == "$DOTFILES_ROOT"* ]] && [[ ! -e "$resolved" ]]; then
                ((broken++))
            fi
        done < <(find "$dir" -mindepth 1 -maxdepth "$maxdepth" -type l 2>/dev/null)
    done
    if [[ $broken -eq 0 ]]; then
        _dotfiles_log_detail "All managed symlinks resolve"
    else
        _dotfiles_log_warning "$broken orphaned symlink(s) — run 'dotfiles clean'"
        ((issues++))
    fi

    # 4. mise leftovers
    _dotfiles_log_step "Checking for stale version manager state"
    if [[ -d "$HOME/.local/share/mise" || -d "$HOME/.config/mise" ]]; then
        _dotfiles_log_warning "mise leftovers detected — run 'dotfiles clean' for cleanup hint"
        ((issues++))
    else
        _dotfiles_log_detail "No mise leftovers"
    fi

    # 5. Per-package doctor (replaces hardcoded vfox check)
    _dotfiles_log_step "Checking packages"
    local pkg_file pkg_name rc
    while IFS= read -r pkg_file; do
        pkg_name="$(basename "$pkg_file" .zsh)"
        pkg_name="${pkg_name#[0-9][0-9]-}"
        _dispatch_pkg_hook "$pkg_file" pkg_doctor
        rc=$?
        case $rc in
            0) ;;  # success — hook already printed its own result
            2) is_verbose && _dotfiles_log_dim "$pkg_name: no pkg_doctor defined (skip)" ;;
            *) _dotfiles_log_warning "$pkg_name: doctor returned $rc"; ((issues+=rc)) ;;
        esac
    done < <(_iter_profile_packages)

    echo
    if [[ $issues -eq 0 ]]; then
        _dotfiles_log_summary "Healthy — 0 issues"
    else
        _dotfiles_log_summary "Found $issues issue(s)"
    fi
    return $issues
}

# =============================================================================
# CLI Package Iteration Helpers
# =============================================================================

# Emit absolute paths of every package file in the active profile, one per line.
# Forward (alphabetical) order. Reverse with a counter loop where needed.
_iter_profile_packages() {
    local profile="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    local -a pkg_dirs
    case "$profile" in
        core|minimal) pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core") ;;
        *)            pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core"
                                "$DOTFILES_ROOT/zsh/packages/full") ;;
    esac
    local dir f
    for dir in "${pkg_dirs[@]}"; do
        [[ -d "$dir" ]] || continue
        for f in "$dir"/*.zsh; do
            [[ -f "$f" ]] && echo "$f"
        done
    done
}

# Run a single package hook via zsh and propagate the helper's exit code.
# Args: <package_file> <hook_name>
# Returns: 0=ok, 1=failure, 2=hook not defined, N=propagated from hook
#
# For pkg_uninstall hooks: creates a temp report file, exports its path into
# the subshell via _PKG_UNINSTALL_REPORT_FILE. On failure the hook writes:
#   ERROR=<message>
#   REMAINING=<paths still on disk>
#   RECOVERY=<command to finish manually>
# The dispatcher reads those into bash-scope vars so uninstall_dotfiles can
# populate its failure-summary table. Unset between packages.
_dispatch_pkg_hook() {
    local pkg_file="$1" hook_name="$2"
    local report_file=""

    if [[ "$hook_name" == "pkg_uninstall" ]]; then
        report_file="$(mktemp)" || report_file=""
    fi

    # Pass all values through env + positional args — NEVER string-interpolate
    # them into the zsh -c script body. A DOTFILES_ROOT path with a space or
    # quote would otherwise corrupt or inject the dispatch.
    DOTFILES_ROOT="$DOTFILES_ROOT" \
    DOTFILES_VERBOSE="${DOTFILES_VERBOSE:-false}" \
    _PKG_UNINSTALL_REPORT_FILE="$report_file" \
    zsh -c '
        source "$DOTFILES_ROOT/zsh/lib/log.sh"
        source "$DOTFILES_ROOT/zsh/lib/platform.zsh"
        source "$DOTFILES_ROOT/zsh/lib/installer.zsh"
        _dotfiles_invoke_package_hook "$1" "$2"
    ' _dispatch_pkg_hook "$pkg_file" "$hook_name"
    local rc=$?

    # Read failure vars from the report file into bash scope
    if [[ -n "$report_file" && -f "$report_file" && $rc -ne 0 ]]; then
        local _line _key _val
        while IFS='=' read -r _key _val; do
            case "$_key" in
                ERROR)     _PKG_UNINSTALL_ERROR="$_val" ;;
                REMAINING) _PKG_UNINSTALL_REMAINING="$_val" ;;
                RECOVERY)  _PKG_UNINSTALL_RECOVERY="$_val" ;;
            esac
        done < "$report_file"
    fi
    [[ -n "$report_file" ]] && rm -f "$report_file"

    return $rc
}

# =============================================================================
# Interactive Menu
# =============================================================================
show_menu() {
    clear
    show_banner

    # Ensure variables are set with defaults
    set_defaults

    echo -e "${BOLD}${WHITE}Current Configuration:${RESET}"
    echo -e "  ${GRAY}OS:${RESET}                  ${MAGENTA}$(get_os_type)${RESET}"
    echo -e "  ${GRAY}Path:${RESET}                ${CYAN}${DOTFILES_ROOT}${RESET}"
    echo -e "  ${GRAY}Profile:${RESET}             ${YELLOW}${DOTFILES_PROFILE}${RESET}"
    echo -e "  ${GRAY}Verbose:${RESET}             ${GREEN}${DOTFILES_VERBOSE}${RESET}"

    echo
    echo -e "${BOLD}${WHITE}Available Actions:${RESET}"
    echo -e "  ${CYAN}1)${RESET} Install      — symlink + packages (no git pull)"
    echo -e "  ${CYAN}2)${RESET} Update       — git pull (stash/rebase/pop)"
    echo -e "  ${CYAN}3)${RESET} Sync         — update + install"
    echo -e "  ${CYAN}4)${RESET} Clean        — remove orphaned symlinks (dry-run)"
    echo -e "  ${CYAN}5)${RESET} Doctor       — read-only health check"
    echo -e "  ${CYAN}6)${RESET} Link         — create/refresh symlinks only"
    echo -e "  ${CYAN}7)${RESET} Packages     — install packages for active profile"
    echo -e "  ${CYAN}8)${RESET} Profile      — change active profile"
    echo -e "  ${CYAN}u)${RESET} Uninstall    — remove all symlinks and dotfiles"
    echo -e "  ${CYAN}t)${RESET} Toggle verbose mode"
    echo -e "  ${CYAN}h)${RESET} Help"
    echo -e "  ${CYAN}q)${RESET} Quit"

    echo
    echo -n "Choose an option [1-8,u,t,h,q]: "
}

interactive_menu() {
    # Load existing configuration for interactive session
    load_config

    while true; do
        show_menu
        read -r choice

        case "$choice" in
            1)
                install_dotfiles
                ;;
            2)
                update_dotfiles
                echo -e "\n${GRAY}Press Enter to continue...${RESET}"
                read -r
                ;;
            3)
                sync_dotfiles
                ;;
            4)
                clean_dotfiles
                echo -e "\n${GRAY}Press Enter to continue...${RESET}"
                read -r
                ;;
            5)
                doctor_dotfiles
                echo -e "\n${GRAY}Press Enter to continue...${RESET}"
                read -r
                ;;
            6)
                create_symlinks
                echo -e "\n${GRAY}Press Enter to continue...${RESET}"
                read -r
                ;;
            7)
                install_packages
                echo -e "\n${GRAY}Press Enter to continue...${RESET}"
                read -r
                ;;
            8)
                echo -n "Enter new profile (core/full): "
                read -r new_profile
                if validate_profile "$new_profile" 2>/dev/null; then
                    export DOTFILES_PROFILE="$new_profile"
                    save_config
                    _dotfiles_log_success "Profile changed to: $new_profile"
                fi
                sleep 2
                ;;
            u)
                uninstall_dotfiles && exit 0
                echo -e "\n${GRAY}Press Enter to continue...${RESET}"
                read -r
                ;;
            t)
                # Toggle verbose mode (for zshrc sourcing only)
                if is_verbose; then
                    export DOTFILES_VERBOSE="false"
                    _dotfiles_log_success "Verbose mode disabled (affects shell startup only)"
                else
                    export DOTFILES_VERBOSE="true"
                    _dotfiles_log_success "Verbose mode enabled (affects shell startup only)"
                fi
                save_config
                sleep 2
                ;;
            h)
                echo
                echo -e "${BOLD}${MAGENTA}Help - Dotfiles Manager${RESET}"
                echo
                echo -e "${BOLD}${WHITE}Installation:${RESET}"
                echo -e "  ${CYAN}${BULLET}${RESET} Download and run (recommended):"
                echo -e "    ${GRAY}curl --proto '=https' --tlsv1.2 -fsSL $INSTALL_COMMAND_URL -o /tmp/dotfiles-install.sh${RESET}"
                echo -e "    ${GRAY}bash /tmp/dotfiles-install.sh${RESET}"
                echo
                echo -e "${BOLD}${WHITE}Profiles:${RESET}"
                echo -e "  ${YELLOW}minimal${RESET}  - Shell essentials (sheldon, tmux)"
                echo -e "  ${YELLOW}server${RESET}   - Shell + utilities + vfox version manager"
                echo
                echo -e "${BOLD}${WHITE}Environment Variables:${RESET}"
                echo -e "  ${CYAN}DOTFILES_ROOT${RESET}     - Installation directory"
                echo -e "  ${CYAN}DOTFILES_PROFILE${RESET}  - Profile selection"
                echo -e "  ${CYAN}DOTFILES_VERBOSE${RESET}  - Verbose logging (affects shell startup only)"
                echo -e "  ${GRAY}Note: dotfiles menu always shows detailed output for debugging${RESET}"
                echo
                echo -e "${GRAY}Press Enter to continue...${RESET}"
                read -r
                ;;
            q)
                save_config
                _dotfiles_log_success "Goodbye!"
                exit 0
                ;;
            *) _dotfiles_log_error "Invalid choice"; sleep 1 ;;
        esac
    done
}

# =============================================================================
# Command Line Interface
# =============================================================================
show_version() {
    echo "dotfiles - Cross-platform dotfiles manager"
    echo "https://github.com/ved0el/dotfiles"
}

show_usage() {
    show_version
    echo
    cat << EOF
USAGE:
  $SCRIPT_NAME [COMMAND] [OPTIONS]

COMMANDS:
  clean       Remove orphaned symlinks pointing into the repo (dry-run default).
  (-c)        Pass --force to apply. Never touches user-created symlinks.
  doctor      Read-only health check: tools, repo, symlinks, packages.
  (-d)        Exit code = number of issues.
  help        Show this help message
  install     Symlink configs and install packages (default).
  (-i)        Does NOT pull from git — safe to run on a dirty working tree.
              For fresh machines: clones the repo first.
  link        Create or refresh symlinks only
  packages    Install required packages for current profile
  profile     Change active profile (core | full)
  sync        Shortcut for: update && install
  (-s)        Pass --stash to auto-stash local changes before pulling.
  uninstall   Remove all symlinks, packages config, and the dotfiles directory
  update      Pull latest changes (warn-and-abort on dirty tree by default).
  (-u)        Pass --stash to auto-stash + rebase + pop.
              Aborts cleanly on conflict, preserving local changes in stash.
  version     Show version information

OPTIONS:
  -v, --verbose    Enable verbose output (shell startup + CLI details)
  -h, --help       Show this help message
  -i               Alias for install
  -u               Alias for update
  -c               Alias for clean
  -d               Alias for doctor
  -s               Alias for sync

EXAMPLES:
  $SCRIPT_NAME                    # Interactive menu
  $SCRIPT_NAME install            # Symlinks + packages (no git)
  $SCRIPT_NAME -i                 # Same as install
  $SCRIPT_NAME update             # Pull latest (aborts if dirty)
  $SCRIPT_NAME update --stash     # Pull + auto-stash local changes
  $SCRIPT_NAME -u --stash         # Same as update --stash
  $SCRIPT_NAME sync               # Pull + reinstall
  $SCRIPT_NAME -d                 # Run health check
  $SCRIPT_NAME profile full       # Switch to full profile
  DOTFILES_PROFILE=full $SCRIPT_NAME install

For more information, visit: $DOCS_URL
EOF
}

# =============================================================================
# Main Function
# =============================================================================
# Initialize script environment
init_script() {
    readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # Load existing configuration and set defaults
    load_config
    set_defaults
}

# Parse and validate command line arguments
parse_args() {
    local command="${1:-}"

    # Handle global options first
    case "$command" in
        -v|--verbose)
            export DOTFILES_VERBOSE="true"
            shift
            command="${1:-}"
            ;;
        -h|--help)
            show_usage
            exit 0
            ;;
        --version)
            show_version
            exit 0
            ;;
    esac

    # Parse commands
    case "$command" in
        ""|install|-i)
            if is_interactive && [[ -z "$command" ]]; then
                interactive_menu
            else
                install_dotfiles
            fi
            ;;
        update|-u)
            update_dotfiles "${2:-}"
            ;;
        sync|-s)
            sync_dotfiles "${2:-}"
            ;;
        clean|-c)
            clean_dotfiles "${2:-}"
            ;;
        doctor|-d)
            doctor_dotfiles
            ;;
        uninstall)
            uninstall_dotfiles
            ;;
        link)
            create_symlinks
            ;;
        profile)
            handle_profile_command "${2:-}"
            ;;
        packages)
            install_packages
            ;;
        version)
            show_version
            ;;
        help|-h|--help)
            show_usage
            ;;
        *)
            if [[ -n "$command" ]]; then
                _dotfiles_log_error "Unknown command: $command"
                echo
                show_usage
                exit 1
            fi
            ;;
    esac
}

# Handle profile command — update only DOTFILES_PROFILE in ~/.zshenv
# Uses targeted sed to replace or append the line (does not rewrite other vars)
handle_profile_command() {
    local new_profile="$1"

    if [[ -z "$new_profile" ]]; then
        _dotfiles_log_error "Profile name required. Usage: $SCRIPT_NAME profile <core|full>"
        return 1
    fi

    if ! validate_profile "$new_profile"; then
        return 1
    fi

    local config_file="$CONFIG_FILE"   # ~/.zshenv

    if grep -q "^export DOTFILES_PROFILE=" "$config_file" 2>/dev/null; then
        # Replace existing line in-place
        sed_inplace "$config_file" \
            "s|^export DOTFILES_PROFILE=.*|export DOTFILES_PROFILE=\"${new_profile}\"|"
    else
        # Append if not present
        echo "export DOTFILES_PROFILE=\"${new_profile}\"" >> "$config_file"
    fi

    export DOTFILES_PROFILE="$new_profile"
    _dotfiles_log_success "Profile set to ${new_profile}. Run: source ~/.zshrc"
    return 0
}

main() {
    init_script
    parse_args "$@"
}

# Run main function with error handling
if main "$@"; then
    exit 0
else
    exit 1
fi
