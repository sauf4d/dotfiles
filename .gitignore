# Claude Code workspace artifacts — PRPs/plans/reports/sessions, etc.
# Already-tracked files (e.g. PRDs deliberately committed) continue to
# track via git's "tracked-files-override-gitignore" rule. To explicitly
# add a new artifact in the future:
#   git add -f .claude/path/to/file
.claude/

zshenv

# mise project-local config — the canonical manifest lives at
# config/mise/config.toml. mise auto-creates a root-level mise.toml when
# `mise use` runs from the repo dir; ignore so it can't be tracked.
/mise.toml
/.mise.toml
config/mise/config.toml
