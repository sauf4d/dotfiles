# Claude Code workspace artifacts — PRPs/plans/reports/sessions, etc.
# Already-tracked files (e.g. PRDs deliberately committed) continue to
# track via git's "tracked-files-override-gitignore" rule. To explicitly
# add a new artifact in the future:
#   git add -f .claude/path/to/file
.claude/

zshenv

# mise project-local + per-machine state — never tracked.
# Synced manifest lives at config/mise/conf.d/*.toml (per-tier shards).
# Each machine's ~/.config/mise/config.toml is local (mise use -g writes
# go there); the 99-machine.toml overlay in conf.d is also machine-local.
# A stray config/mise/config.toml can happen if mise misroutes a write —
# keep it ignored so it can never accidentally enter the repo.
/mise.toml
/.mise.toml
config/mise/config.toml
